---
import 'katex/dist/katex.min.css';
import { parseMathText } from '../lib/math-render.mjs';

interface Props {
  value: string;
  label?: string;
}

type MathSegment =
  | { kind: 'math'; html: string }
  | { kind: 'text'; value: string };

interface MathLine {
  display: boolean;
  segments: MathSegment[];
}

const {
  value,
  label = 'Mathematical update rendered from the source notation',
} = Astro.props;

const lines = parseMathText(value) as MathLine[];
---

<div class="math-record" role="group" aria-label={label}>
  {
    lines.map((line) => {
      const Element = line.display ? 'div' : 'p';

      return (
        <Element
          class={line.display
            ? 'math-record__display'
            : 'math-record__line'}
        >
          {line.segments.map((segment) =>
            segment.kind === 'math' ? (
              <span class="math-record__formula" set:html={segment.html} />
            ) : (
              segment.value
            ),
          )}
        </Element>
      );
    })
  }
</div>

<style>
  .math-record {
    padding: clamp(1rem, 2vw, 1.35rem);
    border: 1px solid var(--atlas-border);
    border-radius: 0.75rem;
    background: var(--atlas-paper-muted);
    color: var(--atlas-ink);
    font-size: 0.98rem;
    line-height: 1.75;
  }

  .math-record :global(.math-record__line) {
    margin: 0;
  }

  .math-record :global(.math-record__line + .math-record__line),
  .math-record :global(.math-record__display + .math-record__line),
  .math-record :global(.math-record__line + .math-record__display) {
    margin-top: 0.65rem;
  }

  .math-record :global(.math-record__display) {
    max-width: 100%;
    padding: 0.35rem 0.15rem 0.45rem;
    overflow-x: auto;
    overflow-y: hidden;
    scrollbar-width: thin;
    text-align: center;
    white-space: nowrap;
  }

  .math-record :global(.katex) {
    font-size: 1.06em;
  }

  .math-record :global(.katex-display) {
    margin: 0;
  }

  .math-record :global(.math-record__display .katex-display) {
    display: inline-block;
  }

  .math-record :global(.math-record__formula) {
    max-width: 100%;
  }

  @media (max-width: 34rem) {
    .math-record {
      padding: 0.9rem;
      font-size: 0.92rem;
      line-height: 1.65;
    }

    .math-record :global(.katex) {
      font-size: 1em;
    }
  }
</style>
