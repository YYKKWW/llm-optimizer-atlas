    grid-template-columns: auto minmax(0, 1fr);
    gap: 0.65rem;
    align-items: start;
    padding: 0.62rem 0.7rem;
    border: 1px solid var(--atlas-border);
    border-radius: 0.55rem;
    cursor: pointer;
  }

  fieldset label:has(input:checked) {
    border-color: var(--atlas-green-border);
    background: var(--atlas-green-soft);
  }

  fieldset input {
    width: 1rem;
    height: 1rem;
    margin-top: 0.1rem;
    accent-color: var(--atlas-burgundy);
  }

  fieldset label span {
    font-size: 0.78rem;
    line-height: 1.45;
  }

  .phase-readings {
    min-width: 0;
    padding-inline-start: 1.2rem;
    border-inline-start: 1px solid var(--atlas-border);
  }

  .reading-heading {
    display: flex;
    gap: 0.8rem;
    justify-content: space-between;
    align-items: baseline;
  }

  .reading-heading h4 {
    margin: 0;
  }

  .reading-heading span {
    color: var(--atlas-muted);
    font-size: 0.66rem;
  }

  .phase-readings ol,
  .frontier-evidence ol {
    display: grid;
    gap: 0.45rem;
    margin: 0.65rem 0 0;
    padding-inline-start: 1.25rem;
  }

  .phase-readings li,
  .frontier-evidence li {
    padding-inline-start: 0.15rem;
    font-size: 0.77rem;
    line-height: 1.4;
  }

  .phase-readings li a,
  .frontier-evidence li a {
    color: var(--atlas-ink);
    font-weight: 650;
    text-decoration-color: color-mix(in srgb, var(--atlas-burgundy) 35%, transparent);
    text-underline-offset: 0.15em;
  }

  .phase-readings li small,
  .frontier-evidence li small {
    display: block;
